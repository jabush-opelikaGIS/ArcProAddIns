<?xml version="1.0" encoding="utf-8" ?>
<ArcGIS defaultAssembly="StreetViewAddin.dll"
        defaultNamespace="StreetViewAddin"
        xmlns="http://schemas.esri.com/DADF/Registry"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://schemas.esri.com/DADF/Registry file:///C:/Program%20Files/ArcGIS/Pro/bin/ArcGIS.Desktop.Framework.xsd">

  <AddInInfo id="{bb76e8d1-2c8d-4bc7-b3e3-66456a8f0c67}" version="1.0" desktopVersion="3.0.0" product="ArcGISPro">
    <Name>Google Street View</Name>
    <Description>Open Google Street View from a clicked map location.</Description>
    <Image>Images\StreetView32.png</Image>
    <Author>Community Release</Author>
    <Company>Community Release</Company>
    <Date>3/20/2026</Date>
    <Subject>Map Exploration</Subject>
  </AddInInfo>

  <modules>
    <insertModule id="StreetViewAddin_Module" className="Module1" autoLoad="false" caption="Google Street View">
      <tabs>
        <tab id="StreetViewAddin_Tab" caption="Google Street View">
          <group refID="StreetViewAddin_Group" />
        </tab>
      </tabs>

      <groups>
        <group id="StreetViewAddin_Group" caption="Tools" appearsOnAddInTab="true">
          <tool refID="StreetViewAddin_OpenStreetViewTool" size="large" />
        </group>
      </groups>

      <controls>
        <tool id="StreetViewAddin_OpenStreetViewTool"
              caption="Open Street View"
              className="Buttons.OpenStreetViewTool"
              loadOnClick="true"
              smallImage="Images\StreetView16.png"
              largeImage="Images\StreetView32.png">
          <tooltip heading="Open Google Street View">Click the map to open Google Street View at that location in your default browser.</tooltip>
        </tool>
      </controls>
    </insertModule>
  </modules>
</ArcGIS>